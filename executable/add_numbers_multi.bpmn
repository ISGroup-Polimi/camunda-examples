  <bpmn:process id="add-numbers-multi" name="add-numbers-multi" isExecutable="true">
    <bpmn:scriptTask id="Activity_1srec5m" name="add numbers script">
      <bpmn:extensionElements>
        <zeebe:script expression="=a+b" resultVariable="sum_script" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1xbrj0t</bpmn:incoming>
      <bpmn:outgoing>Flow_1oi4lke</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:userTask id="Activity_1dztbq9" name="show result">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="add_numbers_results_form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0csepmz</bpmn:incoming>
      <bpmn:outgoing>Flow_004evtc</bpmn:outgoing>
    </bpmn:userTask>
