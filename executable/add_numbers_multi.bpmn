        <zeebe:taskDefinition type="printer-worker" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1y14h56</bpmn:incoming>
      <bpmn:outgoing>Flow_1505xae</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=for i in 1..number(sum_worker) return i" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:serviceTask>
  </bpmn:process>
